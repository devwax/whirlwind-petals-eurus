          "settings": {
            "caption": "Shop for unique gifts from hundreds of Petals designs.",
            "text_style": "uppercase",
            "text_size": 100
          }
        },
        "text_BhjfTx": {
          "type": "text",
          "settings": {
            "text": "<ul><li>Send a gift of lasting beauty, one that’s sure to be remembered.</li><li>Your beautiful gift will arrive in perfect condition.</li><li>Express shipping is available for certain items in our gift collection.</li><li>A free personalized gift card can be included.</li><li>Bring a smile to someone’s face every day.</li><li>All gifts come with our “Seeing is Believing” guarantee.</li></ul>",
