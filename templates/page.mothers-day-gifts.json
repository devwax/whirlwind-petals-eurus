    "custom_liquid_XqryWV": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "custom_liquid": "<style>\n  .petals-mday-benefits {\n    margin: 2rem 0 2.5rem;\n    padding: clamp(1.75rem, 4vw, 2.75rem) clamp(1.25rem, 3vw, 2rem);\n    background: rgb(var(--background-color-secondary, var(--colors-background-secondary, 246 246 246)));\n    border: 1px solid rgba(var(--colors-text), 0.08);\n    border-radius: 4px;\n    color: rgba(var(--colors-text), 1);\n    max-width: 100%;\n    text-align: center;\n  }\n\n  .petals-mday-benefits__intro {\n    margin-bottom: clamp(1.35rem, 3.5vw, 2rem);\n  }\n\n  .petals-mday-benefits__eyebrow {\n    margin: 0 0 0.65rem;\n    font-size: 0.72rem;\n    font-weight: 600;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    opacity: 0.75;\n    line-height: 1.3;\n  }\n\n  .petals-mday-benefits__title {\n    margin: 0 0 0.85rem;\n    font-size: clamp(1.35rem, 2.8vw, 2rem);\n    font-weight: 600;\n    line-height: 1.2;\n    letter-spacing: -0.01em;\n  }\n\n  .petals-mday-benefits__lede {\n    margin: 0 auto;\n    max-width: 52rem;\n    font-size: clamp(0.98rem, 1.65vw, 1.0625rem);\n    line-height: 1.65;\n    opacity: 0.92;\n  }\n\n  /* Row: continuous top & bottom borders; vertical rules between cells on desktop */\n  .petals-mday-benefits__columns {\n    display: grid;\n    grid-template-columns: 1fr;\n    gap: 0;\n    margin: 0;\n    padding: 0;\n    text-align: left;\n    border-top: 1px solid rgba(var(--colors-text), 0.14);\n    border-bottom: 1px solid rgba(var(--colors-text), 0.14);\n  }\n\n  .petals-mday-benefits__col {\n    margin: 0;\n    padding: clamp(1.25rem, 3vw, 2rem) clamp(1rem, 2.5vw, 1.5rem);\n    min-width: 0;\n    background: transparent;\n    border-radius: 0;\n  }\n\n  /* Stacked: separators between stacked blocks */\n  .petals-mday-benefits__col + .petals-mday-benefits__col {\n    border-top: 1px solid rgba(var(--colors-text), 0.14);\n  }\n\n  .petals-mday-benefits__col-title {\n    margin: 0 0 0.5rem;\n    font-size: 0.95rem;\n    font-weight: 600;\n    line-height: 1.3;\n    letter-spacing: -0.01em;\n  }\n\n  .petals-mday-benefits__col-text {\n    margin: 0;\n    font-size: 0.9rem;\n    line-height: 1.58;\n    opacity: 0.88;\n  }\n\n  @media (min-width: 990px) {\n    .petals-mday-benefits__columns {\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n    }\n\n    /* Remove stacking dividers — outer top/bottom + verticals only */\n    .petals-mday-benefits__col + .petals-mday-benefits__col {\n      border-top: none;\n    }\n\n    /* Middle column: left & right borders; left column: right only; right: none extra */\n    .petals-mday-benefits__col:not(:last-child) {\n      border-right: 1px solid rgba(var(--colors-text), 0.14);\n    }\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    .petals-mday-benefits * {\n      transition: none !important;\n    }\n  }\n</style>\n\n<section class=\"petals-mday-benefits\" aria-label=\"Mother's Day gifting benefits\">\n  <div class=\"petals-mday-benefits__intro\">\n    <p class=\"petals-mday-benefits__eyebrow\">Why she’ll love it</p>\n    <h2 class=\"petals-mday-benefits__title\">Thoughtful gifts, beautifully made</h2>\n    <p class=\"petals-mday-benefits__lede\">\n      Celebrate Mother’s Day with floral gifts designed to feel elegant, meaningful,\n      and lasting, bringing beauty into her home long after the day has passed.\n    </p>\n  </div>\n\n  <div class=\"petals-mday-benefits__columns\">\n    <div class=\"petals-mday-benefits__col\">\n      <h3 class=\"petals-mday-benefits__col-title\">Handcrafted realism</h3>\n      <p class=\"petals-mday-benefits__col-text\">\n        Designed with lifelike color, graceful texture, and botanical detail for beauty\n        that feels fresh from the garden.\n      </p>\n    </div>\n    <div class=\"petals-mday-benefits__col\">\n      <h3 class=\"petals-mday-benefits__col-title\">Lasting elegance</h3>\n      <p class=\"petals-mday-benefits__col-text\">\n        A meaningful gift she can enjoy well beyond Mother’s Day, with no watering,\n        wilting, or upkeep required.\n      </p>\n    </div>\n    <div class=\"petals-mday-benefits__col\">\n      <h3 class=\"petals-mday-benefits__col-title\">Effortless gifting</h3>\n      <p class=\"petals-mday-benefits__col-text\">\n        Arrives beautifully prepared for display, making it easy to send something refined,\n        thoughtful, and ready to delight.\n      </p>\n    </div>\n  </div>\n</section>",
        "full_width": false,
        "show_section_divider": false,
