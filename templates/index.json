   color:#FFFFFF !important;\n    border:1px solid #D86557 !important;\n    font-size:12px;\n    line-height:1;\n    letter-spacing:.06em;\n    font-weight:500;\n    text-transform:uppercase;\n    text-decoration:none !important;\n    box-sizing:border-box;\n    transition:background .25s ease, border-color .25s ease, transform .25s ease;\n  }\n\n  .petals-category-banner .petals-category-banner__cta::after{\n    content:\"→\";\n    font-size:14px;\n    color:#FFFFFF !important;\n    transition:transform .25s ease;\n  }\n\n  .petals-category-banner .petals-category-banner__link:hover .petals-category-banner__cta{\n    background:#C85A4D !important;\n    border-color:#C85A4D !important;\n    color:#FFFFFF !important;\n    transform:translateY(-1px);\n  }\n\n  .petals-category-banner .petals-category-banner__link:hover .petals-category-banner__cta::after{\n    transform:translateX(3px);\n  }\n\n  .petals-category-banner__sr-only{\n    position:absolute;\n    width:1px;\n    height:1px;\n    padding:0;\n    margin:-1px;\n    overflow:hidden;\n    clip:rect(0,0,0,0);\n    white-space:nowrap;\n    border:0;\n  }\n\n  @media (max-width:1024px){\n    .petals-category-banner__content{\n      top:12px;\n      width:min(86%,470px);\n    }\n\n    .petals-category-banner__title{\n      font-size:clamp(34px,5vw,48px);\n    }\n\n    .petals-category-banner__subhead{\n      font-size:14px;\n    }\n\n    .petals-category-banner__cta{\n      min-height:38px;\n      min-width:150px;\n      font-size:11px;\n    }\n  }\n\n  @media (max-width:600px){\n    .petals-category-banner__wrap{\n      border-radius:10px;\n    }\n\n    .petals-category-banner__content{\n      position:relative;\n      inset:auto;\n      transform:none;\n      width:auto;\n      padding:22px 20px 28px;\n      background:#FBF8F3;\n      text-align:left;\n    }\n\n    .petals-category-banner__title{\n      font-size:30px;\n    }\n\n    .petals-category-banner__subhead{\n      max-width:100%;\n      font-size:14px;\n    }\n\n    .petals-category-banner__subhead br{\n      display:none;\n    }\n\n    .petals-category-banner__cta{\n      margin-top:18px;\n      min-width:200px;\n    }\n  }\n</style>\n\n<section class=\"petals-category-banner\" aria-label=\"Category banner\">\n  <a class=\"petals-category-banner__link\" href=\"https://petals.com/silk-flower-arrangements\">\n    <div class=\"petals-category-banner__wrap\">\n\n      <picture class=\"petals-category-banner__picture\">\n        <source\n          media=\"(max-width:600px)\"\n          srcset=\"https://cdn11.bigcommerce.com/s-r932bs4ubb/images/stencil/original/image-manager/petals-floral-arrangements-cat-0526-flc154-p-m.jpg?t=1778248002\"\n        >\n\n        <source\n          media=\"(max-width:1024px)\"\n          srcset=\"https://cdn11.bigcommerce.com/s-r932bs4ubb/product_images/uploaded_images/petals-floral-arrangements-cat-0526-flc154-p-bbb.jpg\"\n        >\n\n        <img\n          class=\"petals-category-banner__img\"\n          src=\"https://cdn11.bigcommerce.com/s-r932bs4ubb/product_images/uploaded_images/petals-floral-arrangements-cat-0526-flc154-p-bbb.jpg\"\n          alt=\"Premium handcrafted faux floral arrangement by Petals featuring lifelike roses and seasonal blooms in soft pink, coral, cream, and red tones.\"\n          loading=\"lazy\"\n          decoding=\"async\"\n        >\n      </picture>\n\n      <div class=\"petals-category-banner__content\" aria-hidden=\"true\">\n        <div class=\"petals-category-banner__eyebrow\">\n          Faux Flower Arrangements\n        </div>\n\n        <h2 class=\"petals-category-banner__title\">\n          Forever Florals.\n        </h2>\n\n        <p class=\"petals-category-banner__subhead\">\n          Faux flower arrangements that look real,<br>\n          crafted for lasting beauty season after season.\n        </p>\n\n        <span class=\"petals-category-banner__cta\">\n          Shop Faux Arrangements\n        </span>\n      </div>\n\n      <div class=\"p