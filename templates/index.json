    "custom_liquid_3tyLFq": {
      "type": "custom-liquid",
      "custom_css": [],
      "name": "HP-03 Category-8grid-Custom Liquid",
      "settings": {
        "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;500&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .hp02-category-grid {\n    max-width: 1600px;\n    margin: 0 auto;\n    padding: 30px 32px;\n    background: #ffffff;\n  }\n\n  .hp02-category-grid__inner {\n    display: grid;\n    grid-template-columns: repeat(4, minmax(0, 1fr));\n    gap:34px 28px;\n  }\n\n  .hp02-card {\n    display: block;\n    overflow: hidden;\n    border-radius: 6px;\n    background: #ffffff;\n    text-decoration: none;\n    color: inherit;\n    transition: transform .28s ease, box-shadow .28s ease;\n  }\n\n.hp02-card:hover{\n    transform:translateY(-2px);\n    box-shadow:0 18px 40px rgba(61,52,47,.08);\n}\n\n.hp02-card__image-wrap{\n    aspect-ratio:4 / 4.8;\n    overflow:hidden;\n    background:#ffffff;\n}\n.hp02-card__image {\n  width: 100%;\n  height: 100%;\n  display: block;\n  object-fit: cover;\n  object-position: top center;\n  transition: transform .45s ease;\n}\n\n  .hp02-card:hover .hp02-card__image {\n    transform: scale(1.02);\n  }\n.hp02-card:hover .hp02-card__title {\n    color: #6E8068;\n}\n  .hp02-card__content {\n    padding: 18px 22px 20px;\n    text-align: center;\n  }\n\n.hp02-card__eyebrow{\n    margin:0 0 10px;\n    font-size:10px;\n    line-height:1.2;\n    letter-spacing:.18em;\n    text-transform:uppercase;\n    font-weight:600;\n    color:#8A9B83;\n}\n\n.hp02-card__title{\n    margin:0;\n    font-family:\"Playfair Display\", Georgia, serif;\n    font-size:clamp(32px,2.3vw,38px);\n    line-height:1.02;\n    font-weight:400;\n    font-style:normal;\n    letter-spacing:-0.02em;\n    color:#3D342F;\n\n    transition: color .25s ease;\n}\n\n.hp02-card__copy {\n  margin: 12px auto 0;\n  max-width: 32ch;\n  font-family: \"Inter\", sans-serif;\n  font-size: 14px;\n  line-height: 1.65;\n  font-weight: 400;\n  color: #5B5651;\n}\n  .hp02-card__text-link {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    margin-top: 16px;\n    font-family: \"Inter\", sans-serif;\n    font-size: 11px;\n    letter-spacing: .12em;\n    text-transform: uppercase;\n    font-weight: 700;\n    color: #8A9B83;\n  }\n\n  .hp02-card__text-link::after {\n    content: \"→\";\n    font-size: 14px;\n    transition: transform .25s ease;\n  }\n\n  .hp02-card:hover .hp02-card__text-link::after {\n    transform: translateX(4px);\n  }\n\n  @media screen and (max-width: 1100px) {\n    .hp02-category-grid__inner {\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n    }\n  }\n\n@media screen and (max-width: 640px) {\n\n    .hp02-category-grid {\n      padding: 36px 18px;\n    }\n\n    .hp02-category-grid__inner {\n      grid-template-columns: 1fr;\n      gap: 24px;\n    }\n\n    .hp02-card__content{\n        padding:18px 22px 20px;\n        text-align:center;\n    }\n\n    .hp02-card__title{\n        font-size:clamp(30px,9vw,38px);\n        line-height:1;\n    }\n\n    .hp02-card__copy {\n      margin-left: 0;\n      margin-right: 0;\n      max-width: 100%;\n    }\n}\n</style>\n\n<section class=\"hp02-category-grid\" aria-label=\"Shop Petals categories\">\n  <div class=\"hp02-category-grid__inner\">\n\n    <a class=\"hp02-card\" href=\"/silk-flower-arrangements\">\n      <div class=\"hp02-card__image-wrap\">\n        <img class=\"hp02-card__image\" src=\"https://cdn.shopify.com/s/files/1/0626/3681/8505/files/HP-02-01_arrangements-FLB991-MP.jpg?v=1783205366\" alt=\"Premium faux flower arrangement featuring realistic red and blush roses with lifelike greenery in a clear glass vase by Petals.\" loading=\"lazy\">\n      </div>\n      <div class=\"hp02-card__content\">\n        <p class=\"hp02-card__eyebrow\">Faux Flower Arrangements</p>\n        <h2 class=\"hp02-card__title\">Forever Florals</h2>\n        <p class=\"hp02-card__copy\">Lifelike faux flower arrangements crafted for lasting beauty season after season.</p>\n        <span class=\"hp02-card__text-link\">\nShop Collection\n</span>\n      </div>\n    </a>\n\n    <a class=\"hp02-card\" href=\"/artificial-and-silk-plants\">\n      <div class=\"hp02-card__image-wrap\">\n        <img class=\"hp02-card__image\" src=\"https://cdn.shopify.com/s/files/1/0626/3681/8505/files/HP-02-02_plants-PLD451-GR.jpg?v=1783205366\" alt=\"Realistic artificial tabletop plant with lush green foliage in a decorative planter for effortless year-round style.\" loading=\"lazy\">\n      </div>\n      <div class=\"hp02-card__content\">\n        <p class=\"hp02-card__eyebrow\">Lifelike Greenery</p>\n        <h2 class=\"hp02-card__title\">Perfect Plants</h2>\n        <p class=\"hp02-card__copy\">Carefree botanical style with realistic greenery that stays fresh all year.</p>\n        <span class=\"hp02-card__text-link\">\nShop Collection\n</span>\n      </div>\n    </a>\n\n    <a class=\"hp02-card\" href=\"/artificial-and-silk-trees\">\n      <div class=\"hp02-card__image-wrap\">\n        <img class=\"hp02-card__image\" src=\"https://cdn.shopify.com/s/files/1/0626/3681/8505/files/HP-02-03_Trees-TRF313.jpg?v=1783205366\" alt=\"Lifelike artificial indoor tree with natural branching and realistic foliage for home and office décor.\" loading=\"lazy\">\n      </div>\n      <div class=\"hp02-card__content\">\n        <p class=\"hp02-card__eyebrow\">Elevated Greenery</p>\n        <h2 class=\"hp02-card__title\">Stellar Trees</h2>\n        <p class=\"hp02-card__copy\">Lifelike faux trees that bring natural height, texture, and softness to any room.</p>\n        <span class=\"hp02-card__text-link\">\nShop Collection\n</span>\n      </div>\n    </a>\n\n    <a class=\"hp02-card\" href=\"/silk-floral-arrangements/centerpieces\">\n      <div class=\"hp02-card__image-wrap\">\n        <img class=\"hp02-card__image\" src=\"https://cdn.shopify.com/s/files/1/0626/3681/8505/files/HP-02-04_centerpieces-FLB824.jpg?v=1783205366\" alt=\"Elegant faux floral centerpiece handcrafted with premium artificial flowers for dining tables and seasonal decorating.\" loading=\"lazy\">\n      </div>\n      <div class=\"hp02-card__content\">\n        <p class=\"hp02-card__eyebrow\">Elegant Centerpieces</p>\n        <h2 class=\"hp02-card__title\">Seasonal Gatherings</h2>\n        <p class=\"hp02-card__copy\">Refined faux floral centerpieces for tables, mantels, consoles, and celebrations.</p>\n        <span class=\"hp02-card__text-link\">\nShop Collection\n</span>\n      </div>\n    </a>\n\n    <a class=\"hp02-card\" href=\"/artificial-wreaths-garlands\">\n      <div class=\"hp02-card__image-wrap\">\n        <img class=\"hp02-card__image\" src=\"https://cdn.shopify.com/s/files/1/0626/3681/8505/files/HP-02-05_wreaths-wra375-crf.jpg?v=1783205367\" alt=\"Luxury artificial wreath featuring lifelike greenery and seasonal florals for front doors and interior decorating.\" loading=\"lazy\">\n      </div>\n      <div class=\"hp02-card__content\">\n        <p class=\"hp02-card__eyebrow\">Door & Wall Accents</p>\n        <h2 class=\"hp02-card__title\">Welcome Wreaths</h2>\n        <p class=\"hp02-card__copy\">Artificial wreaths and garlands designed to welcome every season beautifully.</p>\n        <span class=\"hp02-card__text-link\">\nShop Collection\n</span>\n      </div>\n    </a>\n\n    <a class=\"hp02-card\" href=\"/artificial-and-silk-plants/floor-plants\">\n      <div class=\"hp02-card__image-wrap\">\n        <img class=\"hp02-card__image\" src=\"https://cdn.shopify.com/s/files/1/0626/3681/8505/files/HP-02-06_floorplants-pla495-GR.jpg?v=1783205367\" alt=\"Tall artificial floor plant with realistic foliage designed to bring natural beauty to any room.\" loading=\"lazy\">\n      </div>\n      <div class=\"hp02-card__content\">\n        <p class=\"hp02-card__eyebrow\">Statement Greenery</p>\n        <h2 class=\"hp02-card__title\">Floor Plants</h2>\n        <p class=\"hp02-card__copy\">Tall faux plants that add scale, softness, and natural beauty without upkeep.</p>\n        <span class=\"hp02-card__text-link\">\nShop Collection\n</span>\n      </div>\n    </a>\n\n    <a class=\"hp02-card\" href=\"/silk-artificial-arrangement/orchids\">\n      <div class=\"hp02-card__image-wrap\">\n        <img class=\"hp02-card__image\" src=\"https://cdn.shopify.com/s/files/1/0626/3681/8505/files/HP-02-07_orchids-FLB780-CRW.jpg?v=1783205366\" alt=\"Premium faux orchid arrangement with realistic white orchid blooms displayed in an elegant decorative planter.\" loading=\"lazy\">\n      </div>\n      <div class=\"hp02-card__content\">\n        <p class=\"hp02-card__eyebrow\">Refined Botanical Beauty</p>\n        <h2 class=\"hp02-card__title\">Exotic Orchids</h2>\n        <p class=\"hp02-card__copy\">Graceful faux orchid arrangements with elegant blooms and lasting appeal.</p>\n        <span class=\"hp02-card__text-link\">\nShop Collection\n</span>\n      </div>\n    </a>\n\n    <a class=\"hp02-card\" href=\"/silk-flower-stems/flowers\">\n      <div class=\"hp02-card__image-wrap\">\n        <img class=\"hp02-card__image\" src=\"https://cdn.shopify.com/s/files/1/0626/3681/8505/files/HP-02-08-Stems-s4909-pu.jpg?v=1783205366\" alt=\"Realistic artificial flower stems in a variety of premium faux blooms for custom floral arranging.\" loading=\"lazy\">\n      </div>\n      <div class=\"hp02-card__content\">\n        <p class=\"hp02-card__eyebrow\">Design Your Own</p>\n        <h2 class=\"hp02-card__title\">Designer Stems</h2>\n        <p class=\"hp02-card__copy\">Realistic silk flower stems for custom arrangements, styling, and seasonal refreshes.</p>\n        <span class=\"hp02-card__text-link\">\nShop Collection\n</span>\n      </div>\n    </a>\n\n  </div>\n</section>",
