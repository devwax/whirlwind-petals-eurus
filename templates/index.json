    "custom_liquid_4Af4yx": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "BC - Hero Banner - Custom Liquid",
      "settings": {
        "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .petals-home-summer-hero{\n    width:100vw;\n    margin-left:calc(-50vw + 50%);\n    margin-right:calc(-50vw + 50%);\n    position:relative;\n    overflow:hidden;\n    background:#FBF8F3;\n    font-family:\"Inter\",\"Proxima Nova\",\"Avenir Next\",\"Helvetica Neue\",Arial,sans-serif;\n  }\n\n  .petals-home-summer-hero__media{\n    position:relative;\n    width:100%;\n    height:clamp(460px,60vw,720px);\n    overflow:hidden;\n  }\n\n  .petals-home-summer-hero__picture{\n    display:block;\n    width:100%;\n    height:100%;\n    line-height:0;\n    position:relative;\n  }\n\n  .petals-home-summer-hero__picture::after{\n    content:\"\";\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n    z-index:1;\n    background:\n      radial-gradient(circle at 70% 40%, rgba(255,255,255,0.16) 0%, rgba(255,255,255,0.06) 30%, rgba(255,255,255,0) 58%),\n      radial-gradient(circle at 22% 32%, rgba(255,248,240,0.08) 0%, rgba(255,255,255,0) 42%);\n    animation:petalsSummerGlow 10s ease-in-out infinite alternate;\n  }\n\n  .petals-home-summer-hero__img{\n    display:block;\n    width:100%;\n    height:100%;\n    object-fit:cover;\n    object-position:center;\n    transform-origin:center center;\n    animation:petalsSummerBreath 14s ease-in-out infinite alternate;\n    will-change:transform;\n  }\n\n  .petals-home-summer-hero__overlay{\n    position:absolute;\n    inset:0;\n    display:flex;\n    align-items:flex-start;\n    justify-content:center;\n    z-index:2;\n    pointer-events:none;\n    padding-top:34px;\n    box-sizing:border-box;\n  }\n\n  .petals-home-summer-hero__inner{\n    max-width:1600px;\n    margin:0 auto;\n    width:100%;\n    padding:0 48px;\n    box-sizing:border-box;\n  }\n\n  .petals-home-summer-hero__content{\n    pointer-events:auto;\n    text-align:center;\n    margin:0 auto;\n    max-width:900px;\n  }\n\n  .petals-home-summer-hero__eyebrow{\n    margin:0 0 10px 0;\n    font-size:13px;\n    line-height:1.2;\n    letter-spacing:0.16em;\n    text-transform:uppercase;\n    font-weight:600;\n    color:#C85A4D;\n  }\n\n  .petals-home-summer-hero__title{\n    margin:0;\n    font-family:\"Magneta\",\"Cormorant Garamond\",\"Baskerville\",\"Times New Roman\",serif;\n    color:#3D342F;\n    line-height:.92;\n    font-weight:500;\n    white-space:nowrap;\n  }\n\n  .petals-home-summer-hero__title-line1,\n  .petals-home-summer-hero__title-line2{\n    display:inline-block;\n    font-size:72px;\n  }\n\n  .petals-home-summer-hero__title-line2{\n    font-style:italic;\n    margin-left:10px;\n  }\n\n  .petals-home-summer-hero__body{\n    margin:10px auto 0;\n    max-width:690px;\n    font-size:16px;\n    line-height:1.45;\n    letter-spacing:0.01em;\n    color:#4B433F;\n  }\n\n  .petals-home-summer-hero__cta-row{\n    margin-top:22px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  .petals-home-summer-hero__btn{\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    min-width:270px;\n    height:54px;\n    padding:0 32px;\n    background:#D86557;\n    color:#FFFFFF !important;\n    border:1px solid #D86557;\n    text-decoration:none !important;\n    font-size:13px;\n    line-height:1;\n    letter-spacing:0.14em;\n    text-transform:uppercase;\n    font-weight:600;\n    box-sizing:border-box;\n    box-shadow:0 10px 28px rgba(0,0,0,0.08);\n    transition:background .25s ease, border-color .25s ease, transform .25s ease, box-shadow .25s ease;\n  }\n\n  .petals-home-summer-hero__btn:hover{\n    background:#C85A4D;\n    border-color:#C85A4D;\n    color:#FFFFFF !important;\n    transform:translateY(-1px);\n    box-shadow:0 14px 34px rgba(0,0,0,0.12);\n  }\n\n  @media (min-width:1025px) and (max-width:1440px){\n    .petals-home-summer-hero__media{\n      height:clamp(420px,52vw,620px);\n    }\n\n    .petals-home-summer-hero__overlay{\n      padding-top:30px;\n    }\n\n    .petals-home-summer-hero__title-line1,\n    .petals-home-summer-hero__title-line2{\n      font-size:60px;\n    }\n\n    .petals-home-summer-hero__body{\n      font-size:15px;\n      max-width:650px;\n    }\n  }\n\n  @media (max-width:1024px){\n    .petals-home-summer-hero__media{\n      height:clamp(400px,55vw,560px);\n    }\n\n    .petals-home-summer-hero__overlay{\n      padding-top:26px;\n    }\n\n    .petals-home-summer-hero__inner{\n      padding:0 32px;\n    }\n\n    .petals-home-summer-hero__title-line1,\n    .petals-home-summer-hero__title-line2{\n      font-size:48px;\n    }\n\n    .petals-home-summer-hero__body{\n      max-width:560px;\n      font-size:14px;\n      line-height:1.45;\n    }\n\n    .petals-home-summer-hero__cta-row{\n      margin-top:18px;\n    }\n\n    .petals-home-summer-hero__btn{\n      min-width:240px;\n      height:48px;\n      font-size:12px;\n    }\n  }\n\n  @media (max-width:600px){\n    .petals-home-summer-hero__media{\n      height:auto;\n    }\n\n    .petals-home-summer-hero__picture{\n      height:auto;\n    }\n\n    .petals-home-summer-hero__picture::after{\n      display:none;\n    }\n\n    .petals-home-summer-hero__img{\n      width:100%;\n      height:auto;\n      object-fit:cover;\n      object-position:center top;\n      animation:petalsSummerBreathMobile 10s ease-in-out infinite alternate;\n    }\n\n    .petals-home-summer-hero__overlay{\n      position:relative;\n      inset:auto;\n      display:block;\n      padding-top:0;\n      background:#FBF8F3;\n    }\n\n    .petals-home-summer-hero__inner{\n      padding:24px 20px 34px;\n    }\n\n    .petals-home-summer-hero__content{\n      max-width:100%;\n    }\n\n    .petals-home-summer-hero__title{\n      white-space:normal;\n      line-height:.98;\n    }\n\n    .petals-home-summer-hero__title-line1,\n    .petals-home-summer-hero__title-line2{\n      display:inline;\n      font-size:40px;\n    }\n\n    .petals-home-summer-hero__title-line2{\n      margin-left:6px;\n    }\n\n    .petals-home-summer-hero__body{\n      max-width:100%;\n      font-size:15px;\n      line-height:1.5;\n      margin-top:12px;\n    }\n\n    .petals-home-summer-hero__cta-row{\n      margin-top:22px;\n    }\n\n    .petals-home-summer-hero__btn{\n      width:100%;\n      max-width:270px;\n      min-width:0;\n    }\n  }\n\n  @keyframes petalsSummerBreath{\n    0%{ transform:scale(1); }\n    100%{ transform:scale(1.025); }\n  }\n\n  @keyframes petalsSummerGlow{\n    0%{ opacity:.38; }\n    100%{ opacity:.66; }\n  }\n\n  @keyframes petalsSummerBreathMobile{\n    0%{ transform:scale(1); }\n    100%{ transform:scale(1.02); }\n  }\n\n  @media (prefers-reduced-motion:reduce){\n    .petals-home-summer-hero__img,\n    .petals-home-summer-hero__picture::after{\n      animation:none !important;\n      transform:none !important;\n    }\n  }\n</style>\n\n<section class=\"petals-home-summer-hero\" aria-label=\"Summer homepage hero\">\n  <div class=\"petals-home-summer-hero__media\">\n    <picture class=\"petals-home-summer-hero__picture\">\n\n      <source\n        media=\"(max-width:600px)\"\n        srcset=\"https://cdn11.bigcommerce.com/s-r932bs4ubb/images/stencil/original/image-manager/1-hp-mday-hero-mobile-flb944-mp.jpg?t=1778528938\">\n\n      <source\n        media=\"(max-width:1024px)\"\n        srcset=\"https://cdn11.bigcommerce.com/s-r932bs4ubb/images/stencil/original/image-manager/1-hp-mday-hero-tablet-flb944-mp-b.jpg?t=1778533789\">\n\n      <source\n        media=\"(max-width:1440px)\"\n        srcset=\"https://cdn11.bigcommerce.com/s-r932bs4ubb/images/stencil/original/image-manager/1-hp-mday-hero-laptop-flb944-mp-b.jpg?t=1778533788\">\n\n      <img\n        class=\"petals-home-summer-hero__img\"\n        src=\"https://cdn11.bigcommerce.com/s-r932bs4ubb/images/stencil/original/image-manager/1-hp-mday-hero-desktop-flb944-mp-b.jpg?t=1778532849\"\n        alt=\"Luxury summer faux floral arrangement with soft seasonal greenery by Petals\"\n        loading=\"eager\"\n        decoding=\"async\"\n      />\n\n    </picture>\n\n    <div class=\"petals-home-summer-hero__overlay\">\n      <div class=\"petals-home-summer-hero__inner\">\n        <div class=\"petals-home-summer-hero__content\">\n\n          <div class=\"petals-home-summer-hero__eyebrow\">\n            Summer Collection\n          </div>\n\n          <h1 class=\"petals-home-summer-hero__title\">\n            <span class=\"petals-home-summer-hero__title-line1\">Effortless</span>\n            <span class=\"petals-home-summer-hero__title-line2\">Summer.</span>\n          </h1>\n\n          <p class=\"petals-home-summer-hero__body\">\n            Bring home carefree summer beauty with handcrafted faux florals and greenery designed for effortless elegance all season long.\n          </p>\n\n          <div class=\"petals-home-summer-hero__cta-row\">\n            <a href=\"https://petals.com/seasonal-collections/summer\" class=\"petals-home-summer-hero__btn\">\n              Shop Summer Collection\n            </a>\n          </div>\n\n        </div>\n      </div>\n    </div>\n  </div>\n</section>",
