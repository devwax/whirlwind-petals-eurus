ne-height:1;\n    letter-spacing:.06em;\n    font-weight:500;\n    text-transform:uppercase;\n    transition:background .25s ease, transform .25s ease;\n  }\n\n  .petals-category-banner__cta::after{\n    content:\"→\";\n    font-size:14px;\n    transition:transform .25s ease;\n  }\n\n  .petals-category-banner__link:hover .petals-category-banner__cta{\n    background:#7A3E5C;\n    transform:translateY(-1px);\n  }\n\n  .petals-category-banner__link:hover .petals-category-banner__cta::after{\n    transform:translateX(3px);\n  }\n\n  .petals-category-banner__sr-only{\n    position:absolute;\n    width:1px;\n    height:1px;\n    padding:0;\n    margin:-1px;\n    overflow:hidden;\n    clip:rect(0,0,0,0);\n    white-space:nowrap;\n    border:0;\n  }\n\n  /* TABLET */\n  @media (max-width:1024px){\n    .petals-category-banner__content{\n      top:12px;\n      width:min(86%,470px);\n    }\n\n    .petals-category-banner__title{\n      font-size:clamp(34px,5vw,48px);\n    }\n\n    .petals-category-banner__subhead{\n      font-size:14px;\n    }\n\n    .petals-category-banner__cta{\n      min-height:38px;\n      min-width:150px;\n      font-size:11px;\n    }\n  }\n\n  /* MOBILE */\n  @media (max-width:600px){\n    .petals-category-banner__wrap{\n      border-radius:10px;\n    }\n\n    .petals-category-banner__content{\n      position:relative;\n      inset:auto;\n      transform:none;\n      width:auto;\n      padding:22px 20px 28px;\n      background:#f7f4f1;\n      text-align:left;\n    }\n\n    .petals-category-banner__title{\n      font-size:30px;\n    }\n\n    .petals-category-banner__subhead{\n      max-width:100%;\n      font-size:14px;\n    }\n\n    .petals-category-banner__subhead br{\n      display:none;\n    }\n\n    .petals-category-banner__cta{\n      margin-top:18px;\n      min-width:200px;\n    }\n  }\n</style>\n\n<section class=\"petals-category-banner\" aria-label=\"Category banner\">\n  <a class=\"petals-category-banner__link\" href=\"https://petals.com/silk-artificial-arrangement/orchids\">\n    <div class=\"petals-category-banner__wrap\">\n\n      <picture class=\"petals-category-banner__picture\">\n\n        <!-- MOBILE IMAGE -->\n        <source\n          media=\"(max-width:600px)\"\n          srcset=\"https://cdn11.bigcommerce.com/s-r932bs4ubb/images/stencil/original/image-manager/petals-orchids-cat-0526-flc820-m.jpg?t=1778261191\"\n        >\n\n        <!-- TABLET IMAGE -->\n        <source\n          media=\"(max-width:1024px)\"\n          srcset=\"https://cdn11.bigcommerce.com/s-r932bs4ubb/images/stencil/original/image-manager/petals-orchid-cat-0526-flc820.jpg?t=1778261191\"\n        >\n\n        <!-- DESKTOP IMAGE -->\n        <img\n          class=\"petals-category-banner__img\"\n          src=\"https://cdn11.bigcommerce.com/s-r932bs4ubb/images/stencil/original/image-manager/petals-orchid-cat-0526-flc820.jpg?t=1778261191\"\n          alt=\"Realistic faux orchid floral arrangement by Petals with delicate exotic orchid stems designed for year-round beauty and maintenance-free decorating.\"\n          loading=\"lazy\"\n          decoding=\"async\"\n        >\n\n      </picture>\n\n      <div class=\"petals-category-banner__content\" aria-hidden=\"true\">\n        <div class=\"petals-category-banner__eyebrow\">\n          Beauty That Never Fades\n        </div>\n\n        <h2 class=\"petals-category-banner__title\">\n          Eternal Orchids.\n        </h2>\n\n        <p class=\"petals-category-banner__subhead\">\n          Handcrafted faux orchids designed with remarkable realism to bring timeless elegance into every room.\n        </p>\n\n        <span class=\"petals-category-banner__cta\">\n          Shop Faux Orchids\n        </span>\n      </div>\n\n      <div class=\"petals-category-banner__sr-only\">\n        <h2>Eternal Orchids</h2>\n        <p>Handcrafted faux orchids designed with remarkable realism to bring timeless elegance into every room.</p>\n        <p>Shop Faux Orchids.</p>\n      </div>\n\n    </div>\n  </a>\n</section>"
