ne-height:1;\n    letter-spacing:.06em;\n    font-weight:500;\n    text-transform:uppercase;\n    transition:background .25s ease, transform .25s ease;\n  }\n\n  .petals-category-banner__cta::after{\n    content:\"→\";\n    font-size:14px;\n    transition:transform .25s ease;\n  }\n\n  .petals-category-banner__link:hover .petals-category-banner__cta{\n    background:#7A3E5C;\n    transform:translateY(-1px);\n  }\n\n  .petals-category-banner__link:hover .petals-category-banner__cta::after{\n    transform:translateX(3px);\n  }\n\n  .petals-category-banner__sr-only{\n    position:absolute;\n    width:1px;\n    height:1px;\n    padding:0;\n    margin:-1px;\n    overflow:hidden;\n    clip:rect(0,0,0,0);\n    white-space:nowrap;\n    border:0;\n  }\n\n  /* TABLET */\n  @media (max-width:1024px){\n    .petals-category-banner__content{\n      top:12px;\n      width:min(86%,470px);\n    }\n\n    .petals-category-banner__title{\n      font-size:clamp(34px,5vw,48px);\n    }\n\n    .petals-category-banner__subhead{\n      font-size:14px;\n    }\n\n    .petals-category-banner__cta{\n      min-height:38px;\n      min-width:150px;\n      font-size:11px;\n    }\n  }\n\n  /* MOBILE */\n  @media (max-width:600px){\n    .petals-category-banner__wrap{\n      border-radius:10px;\n    }\n\n    .petals-category-banner__content{\n      position:relative;\n      inset:auto;\n      transform:none;\n      width:auto;\n      padding:22px 20px 28px;\n      background:#f7f4f1;\n      text-align:left;\n    }\n\n    .petals-category-banner__title{\n      font-size:30px;\n    }\n\n    .petals-category-banner__subhead{\n      max-width:100%;\n      font-size:14px;\n    }\n\n    .petals-category-banner__subhead br{\n      display:none;\n    }\n\n    .petals-category-banner__cta{\n      margin-top:18px;\n      min-width:200px;\n    }\n  }\n</style>\n\n<section class=\"petals-category-banner\" aria-label=\"Category banner\">\n  <a class=\"petals-category-banner__link\" href=\"https://petals.com/silk-flower-stems/flowers\">\n    <div class=\"petals-category-banner__wrap\">\n\n      <picture class=\"petals-category-banner__picture\">\n\n        <!-- MOBILE IMAGE -->\n        <source\n          media=\"(max-width:600px)\"\n          srcset=\"https://cdn11.bigcommerce.com/s-r932bs4ubb/images/stencil/original/image-manager/petals-stems-cat-0526-s4901-1.jpg?t=1778272858\"\n        >\n\n        <!-- TABLET IMAGE -->\n        <source\n          media=\"(max-width:1024px)\"\n          srcset=\"https://cdn11.bigcommerce.com/s-r932bs4ubb/images/stencil/original/image-manager/petals-stems-cat-0526-s490-b.jpg?t=1778280375\"\n        >\n\n        <!-- DESKTOP IMAGE -->\n        <img\n          class=\"petals-category-banner__img\"\n          src=\"https://cdn11.bigcommerce.com/s-r932bs4ubb/images/stencil/original/image-manager/petals-stems-cat-0526-s490-b.jpg?t=1778280375\"\n          alt=\"Artificial floral stems by Petals including realistic faux roses, greenery, seasonal flowers, and botanical accents for custom bouquet styling and decorating.\"\n          loading=\"lazy\"\n          decoding=\"async\"\n        >\n\n      </picture>\n\n      <div class=\"petals-category-banner__content\" aria-hidden=\"true\">\n        <div class=\"petals-category-banner__eyebrow\">\n         Design Your Own Arrangement\n        </div>\n\n        <h2 class=\"petals-category-banner__title\">\n          Bloom Market\n        </h2>\n\n        <p class=\"petals-category-banner__subhead\">\n          Layer color and texture into your décor with realistic stems designed for effortless styling and endless creativity.\n        </p>\n\n        <span class=\"petals-category-banner__cta\">\n          Shop Single Stems\n        </span>\n      </div>\n\n      <div class=\"petals-category-banner__sr-only\">\n        <h2>Seasonal Gatherings</h2>\n        <pLayer color, texture, and dimension into your décor with realistic faux stems designed for effortless styling and endless creativity.</p>\n        <p>Shop Single Stems\n\n    </div>\n  </a>\n</section>"
          },
          "blocks": {}
        }
