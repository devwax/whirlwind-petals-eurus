{%- comment -%}
  Container picker row backed by theme settings (not collection.products).
  Used for free options that may be unpublished from Online Store.
{%- endcomment -%}
{%- liquid
  assign petals_container_only_handles = 'gold-cover,non-decorative-liner-free-0-00' | split: ','
  assign hide_container_product_url = false
  if petals_container_only_handles contains handle
    assign hide_container_product_url = true
  endif

  assign thumb_url = ''
  assign detail_url = ''
  if image_url != blank
    if image_url contains '?'
      assign thumb_url = image_url | append: '&width=80&height=80&crop=center'
      assign detail_url = image_url | append: '&width=600&height=600&crop=center'
    else
      assign thumb_url = image_url | append: '?width=80&height=80&crop=center'
      assign detail_url = image_url | append: '?width=600&height=600&crop=center'
    endif
  endif
-%}
<li
  class="container-picker__item"
  role="option"
  aria-selected="false"
  data-variant-id="{{ variant_id }}"
  data-product-handle="{{ handle }}"
  {% unless hide_container_product_url %}data-product-url="{{ product_url }}"{% endunless %}
  data-product-title="{{ title | escape }}"
  data-price="{{ price }}"
  data-price-formatted="{% if price == 0 %}FREE{% else %}+ {{ price | money }}{% endif %}"
  data-available="true"
  {% if thumb_url != blank %}
    data-image-url="{{ thumb_url }}"
    data-detail-image-url="{{ detail_url }}"
    data-image-alt="{{ image_alt | default: title | escape }}"
  {% endif %}
>
  <div class="container-picker__item-image">
    {%- if thumb_url != blank -%}
      <img
        src="{{ thumb_url }}"
        alt="{{ image_alt | default: title | escape }}"
        width="80"
        height="80"
        loading="lazy"
      >
    {%- else -%}
      <div class="container-picker__item-image-placeholder"></div>
    {%- endif -%}
  </div>

  <div class="container-picker__item-details">
    <p class="container-picker__item-title">{{ title }}</p>
    <p class="container-picker__item-price">
      {%- if price == 0 -%}
        FREE + $0.00
      {%- else -%}
        + {{ price | money }}
      {%- endif -%}
    </p>
    <p class="container-picker__item-availability container-picker__item-availability--in-stock">
      Available - Est Delivery 5-10 Days
    </p>
  </div>

  <div class="container-picker__item-actions">
    <button
      type="button"
      class="container-picker__item-select-btn"
      aria-label="Select {{ title | escape }}"
    >
      SELECT
    </button>
    <button
      type="button"
      class="container-picker__item-detail-link"
      aria-label="View details for {{ title | escape }}"
      tabindex="-1"
    >Detail</button>
  </div>
</li>
