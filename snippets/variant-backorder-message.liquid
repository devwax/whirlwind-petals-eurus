{% comment %}
  Renders variant-level backorder/delivery message from variant.metafields.big.mpn.

  Accepts:
  - product: {Object} Product Liquid object
  - section: {Object} Section Liquid object
{% endcomment %}

{%- liquid
  assign whirlwind_backorder_property_key = 'Backorder:'
  assign product_form_id = 'product-form-' | append: section.id
  assign placeholder_text = 'Select a variant to see availability'
  assign initial_fully_selected = false
  assign display_message = ''
  assign show_placeholder = false

  if product.has_only_default_variant
    assign initial_fully_selected = true
    assign display_message = product.selected_or_first_available_variant.metafields.big.mpn.value
  elsif product.selected_variant or settings.default_select_available_variant
    assign initial_fully_selected = true
    assign display_variant = product.selected_or_first_available_variant
    if product.selected_variant
      assign display_variant = product.selected_variant
    endif
    assign display_message = display_variant.metafields.big.mpn.value
  else
    assign show_placeholder = true
  endif
-%}

<div
  id="VariantMetafield-{{ section.id }}"
  class="variant-backorder-message{% if show_placeholder %} variant-backorder-message--placeholder{% endif %}"
  data-variant-backorder-message
>
  {%- if show_placeholder -%}
    {{ placeholder_text }}
  {%- elsif display_message != blank -%}
    {{ display_message }}
  {%- endif -%}
</div>

{%- if product.has_only_default_variant and display_message != blank -%}
  <input
    type="hidden"
    name="properties[{{ whirlwind_backorder_property_key }}]"
    value="{{ display_message | escape }}"
    form="{{ product_form_id }}"
  >
{%- endif -%}

<script type="application/json" id="variantMetafieldData-{{ section.id }}">
[
  {%- for variant in product.variants -%}
    {
      "id": {{ variant.id | json }},
      "options": {{ variant.options | json }},
      "metafield": {{ variant.metafields.big.mpn.value | json }}
    }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]
</script>

<div
  id="variant-backorder-config-{{ section.id }}"
  class="hidden"
  data-variant-backorder-config
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-option-count="{{ product.options_with_values.size }}"
  data-form-id="{{ product_form_id }}"
  data-placeholder-text="{{ placeholder_text | escape }}"
  data-has-only-default-variant="{{ product.has_only_default_variant }}"
  data-initial-fully-selected="{{ initial_fully_selected }}"
></div>
