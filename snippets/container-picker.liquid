{% comment %}
  Container Picker - POC
  ----------------------
  Renders a 3-state container selector for products that have one or more
  container collections assigned via metafield.

  Parameters:
    product: {Product} required
    section_id: {String} required — unique id suffix
    product_form_id: {String} optional — required for add mode
    mode: {String} 'add' (default) or 'change'
    only_available: {Boolean} filter unavailable containers
    load_assets: {Boolean} load CSS/JS (default true; false when loaded globally)
{% endcomment %}

{%- assign container_collections = product.metafields.custom.container_collections.value -%}
{%- assign picker_mode = mode | default: 'add' -%}
{%- assign load_picker_assets = load_assets | default: true -%}

{%- if container_collections != blank and container_collections.count > 0 -%}
  {%- if load_picker_assets -%}
    {{- 'component-container-picker.css' | asset_url | stylesheet_tag -}}
  {%- endif -%}

  <container-picker
    class="container-picker{% if picker_mode == 'change' %} container-picker--change-mode{% endif %}"
    id="ContainerPicker-{{ section_id }}"
    data-section-id="{{ section_id }}"
    data-mode="{{ picker_mode }}"
    data-product-id="{{ product.id }}"
    data-product-title="{{ product.title | escape }}"
    {% if product_form_id != blank %}data-product-form-id="{{ product_form_id }}"{% endif %}
    data-money-format="{% if settings.currency_code_enable %}{{ shop.money_with_currency_format | escape }}{% else %}{{ shop.money_format | escape }}{% endif %}"
  >
    <div class="container-picker__header">
      <span class="container-picker__label">
        {%- if picker_mode == 'change' -%}
          Select a new container:
        {%- else -%}
          Container:
        {%- endif -%}
      </span>
      {%- unless picker_mode == 'change' -%}
        <span class="container-picker__required">(Required)</span>
      {%- endunless -%}
    </div>

    <div class="container-picker__box">
    {%- comment -%} Collapsed trigger button — shows "Choose Option" or selected container {%- endcomment -%}
    <button
      type="button"
      class="container-picker__trigger"
      aria-expanded="false"
      aria-controls="ContainerPickerList-{{ section_id }}"
      aria-label="Select container option"
    >
      <span class="container-picker__trigger-placeholder">Choose Option</span>
      <span class="container-picker__trigger-selection" aria-hidden="true" hidden>
        <span class="container-picker__trigger-selection-image" hidden>
          <img
            class="container-picker__trigger-selection-image-el"
            alt=""
            width="40"
            height="40"
            loading="lazy"
          >
        </span>
        <span class="container-picker__trigger-selection-text">
          <span class="container-picker__trigger-selection-name"></span>
          <span class="container-picker__trigger-selection-price"></span>
        </span>
      </span>
      <svg class="container-picker__caret" width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
        <path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <p class="container-picker__error" role="alert" aria-live="polite" hidden></p>

    {%- comment -%} Dropdown list {%- endcomment -%}
    <div
      class="container-picker__dropdown"
      id="ContainerPickerList-{{ section_id }}"
      hidden
    >
      <ul class="container-picker__list" role="listbox" aria-label="Container options">
        {%- for coll in container_collections -%}
          {%- case coll.handle -%}
            {%- when 'ct-ndl' -%}
              {%- if settings.petals_container_ndl_variant_id != blank -%}
                {%- render 'container-picker-pinned-item',
                  variant_id: settings.petals_container_ndl_variant_id,
                  handle: 'non-decorative-liner-free-0-00',
                  title: settings.petals_container_ndl_title,
                  price: 0,
                  image_url: settings.petals_container_ndl_image_url,
                  image_alt: settings.petals_container_ndl_title,
                  product_url: '/products/non-decorative-liner-free-0-00'
                -%}
              {%- endif -%}
            {%- when 'ct-gold' -%}
              {%- if settings.petals_container_gold_variant_id != blank -%}
                {%- render 'container-picker-pinned-item',
                  variant_id: settings.petals_container_gold_variant_id,
                  handle: 'gold-cover',
                  title: settings.petals_container_gold_title,
                  price: 0,
                  image_url: settings.petals_container_gold_image_url,
                  image_alt: settings.petals_container_gold_title,
                  product_url: '/products/gold-cover'
                -%}
              {%- endif -%}
            {%- else -%}
              {%- for container in coll.products limit: 50 -%}
                {%- render 'container-picker-item', container: container, only_available: only_available -%}
              {%- endfor -%}
          {%- endcase -%}
        {%- endfor -%}
      </ul>
    </div>
    </div>

    <p class="container-picker__availability-hint" id="ContainerPickerHint-{{ section_id }}">
      Select an option to check availability
    </p>

    {%- comment -%} Change button — shown only after a selection is made {%- endcomment -%}
    <button
      type="button"
      class="container-picker__change-btn"
      hidden
    >
      Change Selection
    </button>
  </container-picker>

  {%- if load_picker_assets -%}
    <script src="{{ 'container-picker.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
{%- endif -%}
