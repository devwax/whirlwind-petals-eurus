{%- comment -%}
  Petals – Catalog source + sync mirrors for cart drawer (pairs with petals-cart-extras.js & petalsDrawerGiftModal)
{%- endcomment -%}
{{ 'petals-cart-extras.css' | asset_url | stylesheet_tag }}
<div
  class="petals-cart-extras petals-cart-extras--drawer pr-5 pl-5 lg:pr-9 lg:pl-9 pt-3 pb-3 border-solid border-t"
  data-petals-cart-extras
  data-petals-cart-context="drawer"
>
  <input
    type="hidden"
    id="petals-drawer-is-gift-state"
    value="{{ cart.attributes['Is Gift'] | default: '' | escape }}"
  >
  <textarea id="petals-drawer-note-state" class="hidden" aria-hidden="true" tabindex="-1">{{ cart.note }}</textarea>

  <div class="petals-cart-field petals-cart-field--catalog mb-0 pl-3 md:pl-4">
    <label for="petals-cart-drawer-catalog-code" class="petals-cart-label block text-sm font-medium mb-2">
      {{ 'sections.cart.catalog_source_code' | t }}
      <span class="petals-cart-label__hint font-normal opacity-70 text-xs ml-1">
        {{ 'sections.cart.catalog_source_code_hint' | t }}
      </span>
    </label>
    <textarea
      id="petals-cart-drawer-catalog-code"
      name="attributes[Catalog Source Code]"
      form="CartDrawer-Form"
      rows="1"
      class="petals-cart-textarea petals-cart-textarea--drawer-catalog px-3 py-2 text-sm border border-solid border-[rgba(var(--colors-text),0.15)] bg-[rgba(var(--background-color),1)] text-[rgba(var(--colors-text))] focus:outline-none focus:ring-1 focus:ring-[rgba(var(--colors-text),0.2)] placeholder:text-current placeholder:opacity-60"
      data-petals-field="catalog"
      autocomplete="off"
      aria-label="{{ 'sections.cart.catalog_source_code' | t }}"
      placeholder=""
    >{{- cart.attributes['Catalog Source Code'] | escape -}}</textarea>
  </div>
</div>
