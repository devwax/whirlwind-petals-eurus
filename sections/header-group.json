    "custom_liquid_6HAAfD": {
      "type": "custom-liquid",
      "name": "GPS-Global Promotional Strip",
      "settings": {
        "custom_liquid": "<style>\n  .petals-promo-full {\n    --promo-bg:#D86557;\n    --promo-bg-2:#E88E5D;\n    --promo-text: #fffaf2;\n    --promo-muted: rgba(255, 250, 242, 0.65);\n    --promo-border: rgba(255, 250, 242, 0.22);\n    --promo-font: \"Inter\", \"Proxima Nova\", \"Avenir Next\", \"Helvetica Neue\", Arial, sans-serif;\n    --promo-max: 1600px;\n    --promo-pad-x: 48px;\n    --promo-pad-y: 12px;\n\n    width: 100vw;\n    margin-left: calc(-50vw + 50%);\n    background: linear-gradient(110deg, var(--promo-bg) 0%, var(--promo-bg-2) 100%);\n    border-bottom: 1px solid var(--promo-border);\n    position: relative;\n    overflow: hidden;\n    font-family: var(--promo-font) !important;\n    font-synthesis: none;\n    -webkit-font-smoothing: antialiased;\n    text-rendering: geometricPrecision;\n  }\n\n  .petals-promo-full *,\n  .petals-promo-full *::before,\n  .petals-promo-full *::after {\n    box-sizing: border-box;\n  }\n\n  .petals-promo-inner {\n    max-width: var(--promo-max);\n    margin: 0 auto;\n    padding: var(--promo-pad-y) var(--promo-pad-x);\n    text-align: center;\n    position: relative;\n    z-index: 2;\n  }\n\n  .petals-promo-inner a.modallink {\n    font-family: var(--promo-font) !important;\n    font-size: 12.5px !important;\n    font-weight: 600 !important;\n    letter-spacing: 0.11em;\n    text-transform: uppercase;\n    color: var(--promo-text) !important;\n    text-decoration: none !important;\n    display: flex;\n    justify-content: center;\n    flex-wrap: wrap;\n    gap: 8px 12px;\n    line-height: 1.5;\n  }\n\n  .promo-group {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    font-family: var(--promo-font) !important;\n    font-weight: 500 !important;\n  }\n\n  .petals-promo-strong {\n    font-weight: 650 !important;\n  }\n\n  .petals-promo-code {\n    padding: 5px 10px;\n    border-radius: 999px;\n    border: 1px solid rgba(255, 255, 255, 0.38);\n    background: rgba(255, 255, 255, 0.22);\n    color: #fffaf2;\n    font-weight: 700 !important;\n    letter-spacing: 0.14em;\n    white-space: nowrap;\n    font-family: var(--promo-font) !important;\n  }\n\n  .petals-promo-details {\n    font-weight: 600 !important;\n    text-decoration: underline;\n    text-underline-offset: 2px;\n  }\n\n  .dot {\n    width: 4px;\n    height: 4px;\n    border-radius: 999px;\n    background: var(--promo-muted);\n    flex: 0 0 auto;\n  }\n\n  @media (max-width: 768px) {\n    .petals-promo-full {\n      --promo-pad-x: 18px;\n      --promo-pad-y: 11px;\n    }\n\n    .petals-promo-inner a.modallink {\n      font-size: 10.8px !important;\n      letter-spacing: 0.07em;\n      gap: 6px 8px;\n      line-height: 1.45;\n    }\n\n    .promo-group {\n      gap: 6px;\n    }\n\n    .petals-promo-code {\n      padding: 4px 8px;\n    }\n  }\n</style>\n\n<div class=\"petals-promo-full\" role=\"region\" aria-label=\"Summer Savings promotional banner\">\n  <div class=\"petals-promo-inner\">\n    <a\n      class=\"modallink\"\n      data-modal-selector=\"#promomodal\"\n      href=\"javascript:void(0);\"\n      aria-label=\"Summer Savings. Free Shipping on orders $99 or more with code FS99XA. Ends June 28 2026.\"\n    >\n      <span class=\"promo-group\">\n        <span class=\"petals-promo-strong\">Summer Savings</span>\n      </span>\n\n      <span class=\"promo-group\">\n        <span class=\"dot\"></span>\n        <span class=\"petals-promo-strong\">FREE SHIPPING ON $99+</span>\n      </span>\n\n      <span class=\"promo-group\">\n        <span class=\"dot\"></span>\n        <span>USE CODE <span class=\"petals-promo-code\">FS99XA</span></span>\n      </span>\n\n      <span class=\"promo-group\">\n        <span class=\"dot\"></span>\n        <span>ENDS 6/28/26</span>\n      </span>\n\n      <span class=\"promo-group\">\n        <span class=\"dot\"></span>\n        <span class=\"petals-promo-details\">DETAILS</span>\n      </span>\n    </a>\n  </div>\n</div>",
        "full_width": false,
