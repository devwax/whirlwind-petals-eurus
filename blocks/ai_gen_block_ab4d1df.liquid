{% doc %}
  @prompt
    A two-column layout with ability to add HTML coding for each section to feature different collections this site offers.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-column-html-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-two-column-html__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    width: 100%;
  }

  .ai-two-column-html__column-{{ ai_gen_id }} {
    background-color: {{ block.settings.column_background_color }};
    padding: {{ block.settings.column_padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-two-column-html__column-{{ ai_gen_id }} * {
    max-width: 100%;
  }

  .ai-two-column-html__column-{{ ai_gen_id }} img {
    height: auto;
  }

  @media screen and (max-width: 749px) {
    .ai-two-column-html__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.column_gap_mobile }}px;
    }

    .ai-two-column-html__column-{{ ai_gen_id }} {
      padding: {{ block.settings.column_padding_mobile }}px;
    }
  }
{% endstyle %}

<two-column-html-{{ ai_gen_id }} class="ai-two-column-html-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-two-column-html__container-{{ ai_gen_id }}">
    <div class="ai-two-column-html__column-{{ ai_gen_id }} ai-two-column-html__column-left-{{ ai_gen_id }}">
      {% if block.settings.left_column_html != blank %}
        {{ block.settings.left_column_html }}
      {% else %}
        <p style="color: #999; font-style: italic; text-align: center; padding: 40px 20px;">Add HTML content for the left column</p>
      {% endif %}
    </div>

    <div class="ai-two-column-html__column-{{ ai_gen_id }} ai-two-column-html__column-right-{{ ai_gen_id }}">
      {% if block.settings.right_column_html != blank %}
        {{ block.settings.right_column_html }}
      {% else %}
        <p style="color: #999; font-style: italic; text-align: center; padding: 40px 20px;">Add HTML content for the right column</p>
      {% endif %}
    </div>
  </div>
</two-column-html-{{ ai_gen_id }}>

<script>
  (function() {
    class TwoColumnHtml{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('two-column-html-{{ ai_gen_id }}', TwoColumnHtml{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Two column HTML",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Left column"
    },
    {
      "type": "html",
      "id": "left_column_html",
      "label": "HTML content"
    },
    {
      "type": "header",
      "content": "Right column"
    },
    {
      "type": "html",
      "id": "right_column_html",
      "label": "HTML content"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap on desktop",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "column_gap_mobile",
      "label": "Column gap on mobile",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Column style"
    },
    {
      "type": "color",
      "id": "column_background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "column_padding",
      "label": "Padding on desktop",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "column_padding_mobile",
      "label": "Padding on mobile",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Two column HTML"
    }
  ]
}
{% endschema %}
